{
  "architectures": [
    "NemotronHForCausalLM"
  ],
  "vocab_size": 256,
  "hidden_size": 64,
  "intermediate_size": 128,
  "num_hidden_layers": 3,
  "num_attention_heads": 4,
  "num_key_value_heads": 2,
  "head_dim": 16,
  "mamba_num_heads": 4,
  "mamba_head_dim": 8,
  "n_groups": 2,
  "ssm_state_size": 16,
  "conv_kernel": 4,
  "use_conv_bias": true,
  "use_bias": false,
  "rms_norm_eps": 1e-05,
  "tie_word_embeddings": false,
  "eos_token_id": 0,
  "hybrid_override_pattern": "M-*"
}
